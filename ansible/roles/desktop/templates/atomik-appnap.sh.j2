set -euo pipefail
INTERVAL={{ atomik_appnap_interval }}
HIGH_PERCENT={{ atomik_appnap_memory_high }}
CGROUP_BASE="/sys/fs/cgroup"
while true; do
  FOCUSED_PID=""
  if command -v busctl &>/dev/null; then
    if FOCUS_INFO=$(busctl call --user org.gnome.Shell /org/gnome/Shell org.gnome.Shell Eval s 'global.display.focus_window?.get_pid() || 0' 2>/dev/null); then
      FOCUSED_PID=$(echo "$FOCUS_INFO" | sed -n "s/.*'\([0-9]*\)'.*/\1/p")
    elif FOCUS_INFO=$(busctl call --user org.kde.KWin /KWin org.kde.KWin.currentDesktop 2>/dev/null); then
      FOCUSED_PID=$(echo "$FOCUS_INFO" | grep -oP '\d+' | head -1)
    fi
  fi
  if [ -z "$FOCUSED_PID" ] && command -v xdotool &>/dev/null; then
    FOCUSED_PID=$(xdotool getactivewindow getwindowpid 2>/dev/null || true)
  fi
  for scope in $(systemctl --user list-units --type=scope --no-legend --no-pager --plain 2>/dev/null | awk '{print $1}'); do
    CGROUP_PATH=$(systemctl --user show -p ControlGroup "$scope" 2>/dev/null | sed 's/ControlGroup//')
    [ -z "$CGROUP_PATH" ] && continue
    FULL_PATH="${CGROUP_BASE}${CGROUP_PATH}"
    [ ! -f "$FULL_PATH/memory.high" ] && continue
    [ ! -f "$FULL_PATH/memory.current" ] && continue
    IS_FOCUSED=false
    if [ -n "$FOCUSED_PID" ] && [ "$FOCUSED_PID" != "0" ]; then
      if grep -qF "$FOCUSED_PID" "$FULL_PATH/cgroup.procs" 2>/dev/null; then
        IS_FOCUSED=true
      fi
    fi
    if [ "$IS_FOCUSED" = true ]; then
      echo "max" > "$FULL_PATH/memory.high"
    else
      CURRENT=$(cat "$FULL_PATH/memory.current")
      HIGH_VALUE=$((CURRENT * HIGH_PERCENT / 100))
      [ "$HIGH_VALUE" -le "$CURRENT" ] && HIGH_VALUE=$((CURRENT + 1))
      echo "$HIGH_VALUE" > "$FULL_PATH/memory.high"
      if [ -f "$FULL_PATH/memory.reclaim" ]; then
        RECLAIM_VAL=$((CURRENT * 10 / 100))
        if [ "$RECLAIM_VAL" -gt 0 ]; then
          echo "$RECLAIM_VAL" > "$FULL_PATH/memory.reclaim" 2>/dev/null || true
        fi
      fi
    fi
  done
  sleep "$INTERVAL"
done

{
    "extensions.gallery": {
        "serviceUrl": "https://open-vsx.org/api",
        "itemUrl": "https://open-vsx.org",
        "controlUrl": "",
        "cacheUrl": ""
    },
    "extensions.showRecommendationsOnlyOnDemand": true,
    "extensions.ignoreRecommendations": true,
    "extensions.autoCheckUpdates": false,
    "extensions.autoUpdate": false,
    "extensions.enabled": true,
    "extensions.validate": true,
    "telemetry.telemetryLevel": "off",
    "telemetry.enableCrashReporter": false,
    "update.channel": "none",
    "update.mode": "none",
    "workbench.startupEditor": "none",
    "workbench.tips.enabled": false,
    "workbench.editor.enablePreview": true,
    "workbench.editor.enablePreviewFromQuickOpen": true,
    "workbench.layoutControl.enabled": true,
    "workbench.sideBar.location": "left",
    "workbench.activityBar.location": "side",
    "workbench.tree.indent": 16,
    "workbench.list.smoothScrolling": true,
    "workbench.list.scrollablePages": 0,
    "workbench.notification.enabled": false,
    "workbench.colorTheme": "GitHub Dark Default",
    "workbench.iconTheme": "material-icon-theme",
    "workbench.productIconTheme": "Default",
    "material-icon-theme.folders.associations": {
        "ansible": "ansible",
        "deploy": "deployment",
        "terraform": "terraform",
        "k8s": "kubernetes",
        "helm": "kubernetes"
    },
    "material-icon-theme.saturation": 0.85,
    "material-icon-theme.opacity": 1,
    "material-icon-theme.activeIconSet": "current",
    "material-icon-theme.files.associations": {
        "*.yml": "yaml",
        "*.yaml": "yaml",
        "*.toml": "toml",
        "*.ini": "config",
        "*.cfg": "config",
        "Makefile": "makefile",
        "Jenkinsfile": "groovy"
    },
    "[json]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "editor.tabSize": 2,
        "editor.insertSpaces": true
    },
    "[jsonc]": {
        "editor.tabSize": 2,
        "editor.insertSpaces": true
    },
    "[yaml]": {
        "editor.defaultFormatter": "redhat.vscode-yaml",
        "editor.tabSize": 2,
        "editor.insertSpaces": true
    },
    "[markdown]": {
        "editor.wordWrap": "on",
        "editor.tabSize": 2,
        "editor.insertSpaces": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[ansible]": {
        "editor.tabSize": 2,
        "editor.insertSpaces": true,
        "editor.defaultFormatter": "redhat.ansible"
    },
    "[shellscript]": {
        "editor.defaultFormatter": "foxundermoon.shell-format",
        "editor.tabSize": 4,
        "editor.insertSpaces": true
    },
    "[kotlin]": {
        "editor.tabSize": 4,
        "editor.insertSpaces": true
    },
    "workbench.editor.tabSizing": "shrink",
    "workbench.editor.wrapTabs": false,
    "workbench.sideBar.width": 260,
    "workbench.statusBar.visible": true,
    "workbench.editor.showTabs": "multiple",
    "editor.fontSize": 14,
    "editor.fontFamily": "'Noto Sans Mono', 'Cascadia Code', monospace",
    "editor.fontLigatures": true,
    "editor.fontWeight": "normal",
    "editor.lineNumbers": "on",
    "editor.cursorBlinking": "solid",
    "editor.cursorSmoothCaretAnimation": "off",
    "editor.cursorWidth": 2,
    "editor.smoothScrolling": false,
    "editor.minimap.enabled": false,
    "editor.renderLineHighlight": "gutter",
    "editor.bracketPairColorization.enabled": false,
    "editor.guides.bracketPairs": "none",
    "editor.stickyScroll.enabled": false,
    "editor.inlineSuggest.enabled": false,
    "editor.acceptSuggestionOnCommitCharacter": false,
    "editor.tabCompletion": "on",
    "editor.wordWrap": "off",
    "editor.linkedEditing": true,
    "editor.autoClosingBrackets": "always",
    "editor.autoClosingQuotes": "always",
    "editor.autoIndent": "advanced",
    "editor.formatOnPaste": false,
    "editor.formatOnSave": true,
    "editor.formatOnType": false,
    "editor.rulers": [120],
    "editor.renderWhitespace": "selection",
    "editor.folding": true,
    "editor.foldingStrategy": "indentation",
    "editor.showFoldingControls": "mouseover",
    "editor.unfoldOnClickAfterEndOfLine": true,
    "editor.dragAndDrop": false,
    "editor.glyphMargin": false,
    "editor.foldingHighlight": false,
    "editor.overviewRulerBorder": false,
    "editor.hideCursorInOverviewRuler": true,
    "editor.overviewRulerLanes": 0,
    "editor.scrollBeyondLastLine": false,
    "editor.mouseWheelZoom": true,
    "editor.letterSpacing": 0.5,
    "editor.lineHeight": 24,
    "editor.padding.top": 8,
    "editor.padding.bottom": 8,
    "editor.suggestSelection": "first",
    "editor.suggest.showWords": false,
    "editor.suggest.filterGraceful": true,
    "editor.parameterHints.enabled": true,
    "files.autoSave": "afterDelay",
    "files.autoSaveDelay": 1000,
    "files.trimTrailingWhitespace": true,
    "files.insertFinalNewline": true,
    "files.trimFinalNewlines": true,
    "files.exclude": {
        "**/.git": true,
        "**/.DS_Store": true,
        "**/Thumbs.db": true,
        "**/__pycache__": true,
        "**/.pytest_cache": true,
        "**/node_modules": true,
        "**/dist": true,
        "**/build": true,
        "**/.next": true,
        "**/.nuxt": true,
        "**/.output": true,
        "**/.turbo": true,
        "**/.cache": true
    },
    "search.exclude": {
        "**/node_modules": true,
        "**/dist": true,
        "**/build": true,
        "**/.next": true,
        "**/.nuxt": true,
        "**/.output": true,
        "**/.turbo": true,
        "**/*.min.js": true,
        "**/*.min.css": true,
        "**/package-lock.json": true,
        "**/yarn.lock": true,
        "**/pnpm-lock.yaml": true
    },
    "git.autofetch": false,
    "git.confirmSync": false,
    "git.enableSmartCommit": true,
    "git.openRepositoryInParentFolders": "never",
    "terminal.integrated.smoothScrolling": false,
    "terminal.integrated.fontSize": 13,
    "terminal.integrated.fontFamily": "'Noto Sans Mono', monospace",
    "terminal.integrated.scrollback": 5000,
    "terminal.integrated.enableBell": false,
    "terminal.integrated.persistentSessions.enabled": false,
    "http.proxyStrictSSL": true,
    "http.systemCertificates": true,
    "security.workspace.trust.enabled": true,
    "security.workspace.trust.untrustedFiles": "prompt",
    "security.workspace.trust.emptyWindow": true,
    "breadcrumbs.enabled": false,
    "problems.enabled": true,
    "problems.showCurrentInStatus": true,
    "debug.toolBarLocation": "docked",
    "debug.console.fontSize": 13,
    "typescript.tsserver.maxTsServerMemory": 4096,
    "typescript.tsserver.watchOptions": {
        "watchFile": "useFsEvents",
        "watchDirectory": "useFsEvents",
        "fallbackPolling": "dynamicPriority"
    },
    "[python]": {
        "editor.defaultFormatter": "charliermarsh.ruff",
        "editor.tabSize": 4,
        "editor.insertSpaces": true
    },
    "[go]": {
        "editor.defaultFormatter": "golang.go",
        "editor.tabSize": 4,
        "editor.insertSpaces": true
    },
    "[rust]": {
        "editor.defaultFormatter": "rust-lang.rust-analyzer",
        "editor.tabSize": 4,
        "editor.insertSpaces": true
    },
    "[javascript]": {
        "editor.defaultFormatter": "dbaeumer.vscode-eslint",
        "editor.tabSize": 2,
        "editor.insertSpaces": true
    },
    "[typescript]": {
        "editor.defaultFormatter": "dbaeumer.vscode-eslint",
        "editor.tabSize": 2,
        "editor.insertSpaces": true
    }
}
